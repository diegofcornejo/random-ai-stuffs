{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-ce255dca-6775-4391-ad0c-1d87f222006f"
      },
      "enabled": true
    },
    "engram": {
      "command": [
        "/opt/homebrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
		"@warp-dot-dev/opencode-warp"
  ]
}